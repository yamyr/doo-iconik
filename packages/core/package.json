{
  "name": "@ajentik/doo-iconik",
  "version": "1.0.0",
  "description": "Framework-agnostic core icon data and utilities for doo-iconik",
  "license": "MIT",
  "author": "Ajentik",
  "homepage": "https://github.com/ajentik/doo-iconik/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/ajentik/doo-iconik/issues"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./icon-data": {
      "types": "./dist/icon-data.d.ts",
      "import": "./dist/icon-data.js",
      "default": "./dist/icon-data.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "default": "./dist/utils.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js",
      "default": "./dist/icons/*.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js",
      "default": "./dist/icons/index.js"
    }
  },
  "files": ["dist", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  },
  "keywords": ["icons", "doodle", "hand-drawn", "healthcare", "ui", "doo-iconik"],
  "repository": {
    "type": "git",
    "url": "https://github.com/ajentik/doo-iconik.git",
    "directory": "packages/core"
  }
}
