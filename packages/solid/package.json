{
  "name": "@ajentik/doo-iconik-solid",
  "version": "1.0.0",
  "description": "SolidJS component for doo-iconik hand-drawn icons",
  "license": "MIT",
  "author": "Ajentik",
  "homepage": "https://github.com/yamyr/doo-iconik/tree/main/packages/solid",
  "bugs": {
    "url": "https://github.com/yamyr/doo-iconik/issues"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts"
  },
  "dependencies": {
    "@ajentik/doo-iconik": "^1.0.0"
  },
  "peerDependencies": {
    "solid-js": "^1.7.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "jsdom": "^29.0.2",
    "solid-js": "^1.9.12",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite-plugin-solid": "^2.11.12"
  },
  "keywords": [
    "icons",
    "doodle",
    "hand-drawn",
    "solid",
    "solidjs",
    "doo-iconik"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yamyr/doo-iconik.git",
    "directory": "packages/solid"
  }
}
